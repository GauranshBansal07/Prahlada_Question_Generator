          "note": "1,2 vs 1,4 addition; Diels-Alder with dienophile" },
        { "iupac": "2-methylbuta-1,3-diene",   "common": "isoprene",    "formula": "C5H8",   "complexity": 1 },
        { "iupac": "cyclopenta-1,3-diene",     "common": "cyclopentadiene", "formula": "C5H6","complexity": 2,
          "interesting_when": [],
          "note": "Best Diels-Alder diene (s-cis locked); also acidic C-H (pKa ~16)" }
      ]
    },

    "alcohol": {
      "molecules": [
