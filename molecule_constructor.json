        { "iupac": "butan-1-ol",               "common": "n-butanol",   "formula": "C4H10O", "complexity": 1 },
        { "iupac": "butan-2-ol",               "common": "sec-butanol", "formula": "C4H10O", "complexity": 2,
          "interesting_when": ["alcohol_to_alkene"],
          "note": "E2 gives both but-1-ene and but-2-ene; Saytzeff gives but-2-ene (major)" },
        { "iupac": "(R)-butan-2-ol",           "common": "(R)-2-butanol","formula": "C4H10O","complexity": 3,
          "interesting_when": ["alcohol_to_alkyl_halide"],
          "note": "Chiral: SOCl2/pyridine gives INVERSION; SNi gives RETENTION" }
      ]
    },

    "alkyl_halide": {
      "molecules": [
        { "iupac": "2-bromopropane",           "common": "isopropyl bromide","formula": "C3H7Br", "complexity": 1 },
        { "iupac": "2-bromo-2-methylpropane",  "common": "tert-butyl bromide","formula": "C4H9Br","complexity": 1,
