          "note": "Secondary alcohol: E2 gives propene; Lucas test slower than tertiary" },
        { "iupac": "2-methylpropan-2-ol",      "common": "tert-butanol","formula": "C4H10O", "complexity": 1,
          "interesting_when": ["alcohol_to_alkene"],
