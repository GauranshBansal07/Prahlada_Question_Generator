{
  "_meta": {
    "purpose": "Per-node rules for generating concrete IUPAC molecules when the graph traversal picks a node. Each node has a pool of molecule templates. The generator samples one, scales complexity by difficulty, and applies IUPAC semantic obfuscation.",
    "fields": {
      "node_id": "Canonical graph node ID",
      "molecules": "Pool of concrete molecule examples for this node class",
      "iupac_preferred": "IUPAC name (required for semantic_obfuscation meta-tag)",
      "complexity": "1-3: how structurally complex (1=simple chain, 3=chiral/cyclic/polyfunctional)",
      "interesting_when": "List of edge IDs or conditions where this molecule makes for a good question (rich stereochemistry, rearrangement, etc.)",
      "avoid_with": "List of edge IDs where this molecule is too simple or misleading"
    }
  },

  "nodes": {
    "alkane": {
      "molecules": [
        { "iupac": "propane",                  "common": "propane",     "formula": "C3H8",   "complexity": 1 },
        { "iupac": "butane",                   "common": "butane",      "formula": "C4H10",  "complexity": 1 },
        { "iupac": "2-methylpropane",          "common": "isobutane",   "formula": "C4H10",  "complexity": 1,
          "interesting_when": ["alkane_to_alkyl_halide"],
          "note": "Two distinct H environments → selectivity question" },
        { "iupac": "2-methylbutane",           "common": "isopentane",  "formula": "C5H12",  "complexity": 2,
          "interesting_when": ["alkane_to_alkyl_halide"],
          "note": "3 distinct H environments → monobromination selectivity" },
        { "iupac": "2,2-dimethylpropane",      "common": "neopentane",  "formula": "C5H12",  "complexity": 2,
          "interesting_when": ["alkane_to_alkyl_halide"],
          "note": "All 12 H equivalent → single monobromination product" }
      ],
      "generation_rule": "For chain length n=3-6, prefer branched isomers for selectivity questions"
    },

    "alkene": {
      "molecules": [
        { "iupac": "prop-1-ene",               "common": "propene",     "formula": "C3H6",   "complexity": 1 },
        { "iupac": "but-1-ene",                "common": "1-butene",    "formula": "C4H8",   "complexity": 1 },
        { "iupac": "but-2-ene",                "common": "2-butene",    "formula": "C4H8",   "complexity": 1,
          "stereo_variants": ["(E)-but-2-ene", "(Z)-but-2-ene"],
          "interesting_when": ["alkene_to_vicinal_dihalide", "alkene_to_diol"],
          "note": "Anti addition → meso vs racemic distinction; classic JEE stereochemistry" },
        { "iupac": "2-methylprop-1-ene",       "common": "isobutylene", "formula": "C4H8",   "complexity": 1,
          "interesting_when": ["alkene_to_alkyl_halide", "alkene_to_alcohol"],
          "note": "Markovnikov regioselectivity: gives tertiary product" },
        { "iupac": "pent-1-ene",               "common": "1-pentene",   "formula": "C5H10",  "complexity": 2 },
        { "iupac": "cyclohex-1-ene",           "common": "cyclohexene", "formula": "C6H10",  "complexity": 2,
          "interesting_when": ["alkene_to_diol", "alkene_to_epoxide", "alkene_to_halohydrin"],
          "note": "Cyclic alkene: syn addition → cis diol; anti addition → trans product" },
        { "iupac": "styrene",                  "common": "styrene",     "formula": "C8H8",   "complexity": 2,
          "interesting_when": ["alkene_to_alkyl_halide"],
          "note": "Benzylic carbocation stabilization → Markovnikov always gives benzylic product" }
      ],
      "generation_rule": "Prefer disubstituted for stereochemistry questions; monosubstituted for Markovnikov/anti-Markovnikov"
    },

    "alkyne": {
      "molecules": [
        { "iupac": "ethyne",                   "common": "acetylene",   "formula": "C2H2",   "complexity": 1,
          "interesting_when": ["alkyne_to_acetylide_ion"],
          "note": "Both H acidic; forms dicarbanion with excess NaNH2" },
        { "iupac": "prop-1-yne",               "common": "propyne",     "formula": "C3H4",   "complexity": 1,
          "interesting_when": ["alkyne_to_acetylide_ion", "alkyne_to_alkene"] },
        { "iupac": "but-1-yne",                "common": "1-butyne",    "formula": "C4H6",   "complexity": 1 },
        { "iupac": "but-2-yne",                "common": "2-butyne",    "formula": "C4H6",   "complexity": 1,
          "interesting_when": ["alkyne_to_alkene"],
          "note": "Internal alkyne: Lindlar gives (Z)-alkene; Na/liq NH3 gives (E)-alkene" }
      ],
      "generation_rule": "Terminal alkynes for Grignard/alkylation; internal for cis/trans hydrogenation"
    },

    "diene_conjugated": {
      "molecules": [
        { "iupac": "buta-1,3-diene",           "common": "1,3-butadiene", "formula": "C4H6", "complexity": 1,
