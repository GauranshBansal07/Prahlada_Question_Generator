      "id": "2022Mains_26JulEvening_Chem_Q1",
      "year": 2022,
      "paper": "26JulEvening",
      "question_number": 1,
      "question_text": "Hemoglobin contains 0.34% of iron by mass. The number of Fe atoms in 3.3 g of hemoglobin is: (Given: Atomic mass of Fe is 56 u, N_A = 6.022 × 10²³ mol⁻¹)",
      "question_type": "MCQ",
      "marks": 4,
      "topic": "Physical Chemistry - Mole Concept",
      "sub_topic": "Mass percentage and atom count",
      "correct_answer": "C",
      "solution_summary": "Mass of Fe in 3.3 g hemoglobin = 0.34/100 × 3.3 = 0.01122 g. Moles Fe = 0.01122/56. Number of Fe atoms = (0.01122/56) × 6.022 × 10²³ = 1.206 × 10²⁰.",
      "concepts_required": [
        "SBC_22",
        "SBC_24",
        "SBC_28"
